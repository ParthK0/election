# Server-side AI key — NEVER use VITE_ prefix (would expose to client bundle)
GEMINI_API_KEY=your_server_side_gemini_key_here

# Firebase client-side config (safe to expose — these are public identifiers)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ReCaptcha v3 site key for Firebase App Check (get from console.firebase.google.com)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
