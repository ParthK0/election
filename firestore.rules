rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Quiz scores: write-only with strict field validation
    match /quizScores/{document=**} {
      allow write: if request.resource.data.keys().hasAll(['score', 'difficulty', 'timestamp', 'country'])
                   && request.resource.data.score is number
                   && request.resource.data.score >= 0
                   && request.resource.data.score <= 100
                   && request.resource.data.difficulty in ['Beginner', 'Intermediate', 'Expert'];
      allow read: if false;
    }

    // AI message feedback: write-only, validated fields
    match /feedback/{document=**} {
      allow write: if request.resource.data.keys().hasAll(['type', 'country', 'timestamp'])
                   && request.resource.data.type in ['helpful', 'not_helpful'];
      allow read: if false;
    }

    // Global stats: read-only for clients (written by Cloud Functions)
    match /stats/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

